# Optional Glitch runtime integration.
# Set to 1 only for builds that should validate installs and use Glitch services.
NEXT_PUBLIC_GLITCH_ENABLED=0
NEXT_PUBLIC_GLITCH_API_URL=https://api.glitch.fun/api

# Build target hint used by deploy scripts and the runtime route detector.
NEXT_PUBLIC_GLITCH_GAME_KEY=isocity

# Public runtime title tokens. These are title-token runtime credentials, not deploy tokens.
# They are exposed to browser builds by design, so never put deploy/admin/server tokens here.
NEXT_PUBLIC_GLITCH_ISOCITY_TITLE_TOKEN=
NEXT_PUBLIC_GLITCH_COASTER_TITLE_TOKEN=

# Optional dashboard-defined progression keys. Leave blank until the boards/stats exist in Glitch.
NEXT_PUBLIC_GLITCH_ISOCITY_LEADERBOARD_KEYS=
NEXT_PUBLIC_GLITCH_ISOCITY_STAT_KEYS=
NEXT_PUBLIC_GLITCH_COASTER_LEADERBOARD_KEYS=
NEXT_PUBLIC_GLITCH_COASTER_STAT_KEYS=

# Deploy tokens. These are server/developer-machine only and must not be prefixed NEXT_PUBLIC.
GLITCH_ISOCITY_DEPLOY_TOKEN=
GLITCH_COASTER_DEPLOY_TOKEN=

# Deploy script convenience aliases for runtime title tokens.
GLITCH_ISOCITY_TITLE_TOKEN=
GLITCH_COASTER_TITLE_TOKEN=

